{
    "name": "plytas/cow",
    "description": "CLI for managing APFS copy-on-write git clones with Laravel Valet integration.",
    "keywords": ["cli", "git", "valet", "clone", "apfs"],
    "homepage": "https://github.com/Plytas/cow",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/Plytas/cow/issues",
        "source": "https://github.com/Plytas/cow"
    },
    "authors": [
        {
            "name": "Vytautas Smilingis",
            "email": "vytautas@smilingis.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel-zero/framework": "^12.0.2",
        "laravel-zero/phar-updater": "^1.4",
        "laravel/prompts": "^0.3.17"
    },
    "require-dev": {
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["cow"]
}
